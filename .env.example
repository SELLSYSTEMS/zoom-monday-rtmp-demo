ZOOM_BASE_URL=https://api.zoom.us/v2
ZOOM_TOKEN_URL=https://zoom.us/oauth/token

# Preferred Server-to-Server OAuth handoff values for operators or agents.
# When these are set, the CLI mints a fresh token automatically.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Optional direct override if you want to pass a short-lived token manually.
ZOOM_ACCESS_TOKEN=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_USER_ID=me
ZOOM_DEFAULT_JOIN_URL_BASE=https://zoom.us/j

MONDAY_API_URL=https://api.monday.com/v2
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_ZOOM_LINK_COLUMN_ID=
MONDAY_RECORDING_LINK_COLUMN_ID=
MONDAY_STATUS_COLUMN_ID=

RTMP_STREAM_BASE=rtmp://example.com/live
RTMP_PAGE_BASE=https://example.com/player
RTMP_RESOLUTION=720p

# Important:
# RTMP_STREAM_BASE is the public URL that Zoom must reach.
# It may include a public high port, for example:
# rtmp://instance.example.com:49224/live
# even if the local nginx RTMP service inside the instance listens on a
# different port such as 1880.
#
# RTMP_PAGE_BASE is the public human-facing live page base.
# The current clean runtime expects page_url values like:
# https://instance.example.com/player/<stream-key>

RECORDINGS_DIR=/var/lib/zoom-monday-rtmp-demo/recordings
RECORDING_STABLE_SECONDS=15
