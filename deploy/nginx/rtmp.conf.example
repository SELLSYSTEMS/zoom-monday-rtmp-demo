rtmp {
    server {
        listen __RTMP_LISTEN_PORT__;
        chunk_size 4096;

        application live {
            live on;

            record all;
            record_path /var/lib/zoom-monday-rtmp-demo/recordings;
            record_suffix .flv;
            record_unique on;

            hls on;
            hls_path /var/lib/zoom-monday-rtmp-demo/hls;
            hls_fragment 4s;
            hls_playlist_length 30s;
            hls_nested on;
            hls_cleanup on;
        }
    }
}
