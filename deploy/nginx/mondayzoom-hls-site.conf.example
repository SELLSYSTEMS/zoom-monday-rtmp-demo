server {
    listen 80;
    listen [::]:80;

    server_name mondayzoom.sellsystems.agency;

    access_log /var/log/nginx/mondayzoom_access.log;
    error_log /var/log/nginx/mondayzoom_error.log;

    location = /healthz {
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    location /hls/ {
        types {
            application/vnd.apple.mpegurl m3u8;
            video/mp2t ts;
        }
        alias /var/lib/zoom-monday-rtmp-demo/hls/;
        add_header Cache-Control no-cache;
        add_header Access-Control-Allow-Origin *;
    }

    location /recordings/ {
        types {
            video/x-flv flv;
        }
        alias /var/lib/zoom-monday-rtmp-demo/recordings/;
        add_header Cache-Control no-cache;
        add_header Access-Control-Allow-Origin *;
        autoindex off;
    }
}
